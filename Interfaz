// =================================================================================
// SECCIÓN 1: CONTROL DE PALETA DE COLORES ANSI (Estándar de Consola)
// =================================================================================
const std::string RESET   = "\033[0m";
const std::string AZUL    = "\033[34m"; // Color exclusivo de la Nave Orión-X9
const std::string ROJO    = "\033[31m"; // Alertas, colisiones y fallos
const std::string VERDE   = "\033[32m"; // Éxito, Tierra y elementos salvados
const std::string AMARILLO= "\033[33m"; // Telemetría de tiempo y Luna
const std::string CIAN    = "\033[36m"; // Bordes de contenedores y HUD

// Limpieza de buffer y pantalla compatible con terminales modernos
void limpiarPantalla() {
    std::cout << "\033[2J\033[1;1H";
}

// =================================================================================
// SECCIÓN 2: WBS 1.2.1 - CONTROL DE ASSETS GRÁFICOS (ARTE ASCII)
// =================================================================================

void dibujarTierra() {
    std::cout << VERDE << R"(
     .-----.
   .-   _   -.
  /  .-' ' -. \
  |  |  T-1   | |
  \  '-_ _ -' /
   '-_     _-'
      '-----'
)" << RESET;
}

void dibujarLuna() {
    std::cout << AMARILLO << R"(
     .-----.
   .-  ( )  -.
  /  o      o \
  |    ( )    |
  \  o      o /
   '-_     _-'
      '-----'
)" << RESET;
}

void dibujarNave() {
    std::cout << AZUL << R"(    /---.
====|===##[>)
    \---')" << RESET << std::endl;
}

void dibujarAstronauta() {
    std::cout << VERDE << " o \n/|\\\n/ \\" << RESET << std::endl;
}

void dibujarMeteorito() {
    std::cout << ROJO << " (*)" << RESET << std::endl;
}

// =================================================================================
// SECCIÓN 3: WBS 1.2.3 - PANEL DE CONTROL DINÁMICO (HUD DE TELEMETRÍA)
// =================================================================================
void mostrarHUD(int pasajeros, int tiempoRestante, int vidas, int velocidad) {
    std::cout << CIAN << "=================================================================================" << RESET << std::endl;
    std::cout << " MISIÓN: ARTEMIS II | NAVE: " << AZUL << "ORIÓN-X9" << RESET 
              << " | CAPACIDAD EN CABINA: [" << pasajeros << " / 2] ASTRONAUTAS" << std::endl;
    std::cout << CIAN << "---------------------------------------------------------------------------------" << RESET << std::endl;
    
    std::cout << " CRONÓMETRO DE REENTRADA: " << AMARILLO << tiempoRestante << "s" << RESET << " | INTEGRIDAD RESIDUOS: ";
    
    // Renderizado iterativo de indicadores de salud física (Corazones ANSI)
    for (int i = 0; i < 3; i++) {
        if (i < vidas) std::cout << ROJO << "[♥] " << RESET;
        else std::cout << "[ ] ";
    }
    
    std::cout << " | VELOCIDAD RECOMBINANTE: " << velocidad << " km/s" << std::endl;
    std::cout << CIAN << "=================================================================================" << RESET << std::endl;
}

