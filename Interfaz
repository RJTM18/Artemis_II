#ifndef INTERFAZ_H
#define INTERFAZ_H

#include <iostream>
#include <string>

// =================================================================================
// CONTROL DE COLORES ANSI
// =================================================================================
const std::string RESET   = "\033[0m";
const std::string AZUL    = "\033[34m";
const std::string ROJO    = "\033[31m";
const std::string VERDE   = "\033[32m";
const std::string AMARILLO= "\033[33m";
const std::string CIAN    = "\033[36m";

// Limpieza de pantalla eficiente para sistemas POSIX/Windows moderno
void limpiarPantalla() {
    std::cout << "\033[2J\033[1;1H";
}

// =================================================================================
// WBS 1.2.1: ASSETS EN ARTE ASCII
// =================================================================================

void dibujarTierra() {
    std::cout << VERDE << R"(
     .-----.
   .-   _   -.
  /  .-' ' -. \
  |  |  T-1   | |
  \  '-_ _ -' /
   '-_     _-'
      '-----'
)" << RESET;
}

void dibujarLuna() {
    std::cout << AMARILLO << R"(
     .-----.
   .-  ( )  -.
  /  o      o \
  |    ( )    |
  \  o      o /
   '-_     _-'
      '-----'
)" << RESET;
}

// Nave pintada en AZUL obligatorio por requerimiento
void dibujarNave() {
    std::cout << AZUL << R"(    /---.
====|===##[>)
    \---')" << RESET << std::endl;
}

void dibujarAstronauta() {
    std::cout << VERDE << " o \n/|\\\n/ \\" << RESET << std::endl;
}

void dibujarMeteorito() {
    std::cout << ROJO << " (*)" << RESET << std::endl;
}

// =================================================================================
// WBS 1.2.3: PANEL DE CONTROL (HUD)
// =================================================================================
void mostrarHUD(int pasajeros, int tiempoRestante, int vidas, int velocidad) {
    std::cout << CIAN << "=================================================================================" << RESET << std::endl;
    std::cout << " MISIÓN: ARTEMIS II | NAVE: " << AZUL << "ORIÓN-X9 (AZUL)" << RESET 
              << " | CAPACIDAD: [" << pasajeros << " / 2] ASTRONAUTAS" << std::endl;
    std::cout << CIAN << "---------------------------------------------------------------------------------" << RESET << std::endl;
    
    std::cout << " TIEMPO RESTANTE: " << AMARILLO << tiempoRestante << "s" << RESET << " | VIDAS: ";
    
    // Renderizado dinámico de corazones según el estado que pase Armando
    for (int i = 0; i < 3; i++) {
        if (i < vidas) std::cout << ROJO << "[♥] " << RESET;
        else std::cout << "[ ] ";
    }
    
    std::cout << " | VELOCIDAD ACTUAL: " << velocidad << " km/s" << std::endl;
    std::cout << CIAN << "=================================================================================" << RESET << std::endl;
}

